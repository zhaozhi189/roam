# ===== macOS =====
.DS_Store
.AppleDouble
.LSOverride
._*

# ===== JetBrains IDE =====
.idea/
*.iml
*.iws
*.ipr

# ===== VS Code =====
.vscode/
*.code-workspace

# ===== Node / Vite (前端) =====
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
.eslintcache
.parcel-cache/
.cache/

# 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===== Cloudflare Workers / Pages =====
.wrangler/
.dev.vars
.dev.vars.*
wrangler.toml.bak

# ===== Android Studio / Gradle =====
.gradle/
**/build/
local.properties
captures/
*.apk
!docs/roam-debug.apk
*.aab
*.ap_
*.dex
.cxx/
# Android Studio 项目文件中除了少量 share 的,其余都忽略(.idea/ 全忽略已上面规则覆盖)
# 例外:Android 模块下保留 release keystore 占位但不入实际 keystore
*.keystore
*.jks
# SPZ / SOG 测试素材如果放在 android/app/src/main/assets/ 也算大文件,默认忽略
android/app/src/main/assets/test-*.spz

# ===== 环境变量 / 密钥 =====
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ===== 测试 / 覆盖率 =====
coverage/
*.lcov
.nyc_output/

# ===== 3DGS / 大文件实验产物(本地玩,不入库)=====
*.ply
*.splat
*.sog
# 例外:示例数据 & vendor 进 App 的 PlayCanvas 官方公开 demo 必须入库(git clone 即可装机)
!doc/**/*.sog
!client/app/src/main/assets/scenes/**
# ADR-010 · docs/scenes/ 远程样例必须入库给 GitHub Pages 服务
!docs/scenes/**

# ===== 日志 =====
*.log
logs/

# ===== 临时文件 =====
*.tmp
*.swp
*.swo
*~
.tmp/
tmp/

# ===== 操作系统其他 =====
Thumbs.db
ehthumbs.db
Desktop.ini
